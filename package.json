{
  "name": "@veedubin/super-memory-ts",
  "version": "2.4.2",
  "description": "Super-Memory MCP server with local embeddings and vector search",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Veedubin/Super-Memory-TS.git"
  },
  "homepage": "https://github.com/Veedubin/Super-Memory-TS#readme",
  "bugs": {
    "url": "https://github.com/Veedubin/Super-Memory-TS/issues"
  },
  "files": [
    "dist/",
    "bin/",
    "scripts/",
    "package.json",
    "README.md",
    "NPM_README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "super-memory-ts": "./bin/super-memory-ts.cjs"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@xenova/transformers": "^2.0.1",
    "chokidar": "^4.0.0",
    "fuse.js": "^7.0.0",
    "glob": "^13.0.6",
    "xxhash-wasm": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^22.5.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
