{
  "database": {
    "dbPath": "http://localhost:6333",
    "tableName": "memories"
  },
  "model": {
    "precision": "fp16",
    "device": "gpu",
    "useGpu": true,
    "embeddingDim": 1024,
    "batchSize": 32
  },
  "indexer": {
    "chunkSize": 512,
    "chunkOverlap": 50,
    "maxFileSize": 10485760,
    "excludePatterns": ["node_modules", ".git", "dist", "*.log", ".DS_Store"]
  },
  "logging": {
    "level": "info"
  },
  "performance": {
    "workers": 8,
    "maxHeapMB": 8192,
    "flushIntervalMs": 50,
    "flushThreshold": 10,
    "memoryThreshold": 0.7,
    "maxBufferBytes": 52428800,
    "indexOnStartup": true,
    "pauseIndexingDuringRequests": true,
    "periodicScanIntervalMs": 300000,
    "yieldMs": 10
  }
}